# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.py]
indent_size = 4

[*.go]
indent_size = 4

[*.rs]
indent_size = 4

[*.c]
indent_size = 4

[*.cpp]
indent_size = 4

[*.h]
indent_size = 4

[*.java]
indent_size = 4